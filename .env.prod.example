# OCI VM에서 docker-compose.prod.yml 실행 전 .env 파일로 복사해서 값 채우기
# cp .env.prod.example .env

# MySQL
DB_USERNAME=devtoolbox
DB_PASSWORD=your-db-password
DB_ROOT_PASSWORD=your-root-password

# Spring Boot Admin
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your-admin-password

# 프론트엔드 도메인 (Vercel 배포 URL)
CORS_ORIGIN=https://devtoolbox.vercel.app

# 백엔드 공개 URL (파일 다운로드 링크 생성용)
STORAGE_BASE_URL=https://api.yourdomain.com
