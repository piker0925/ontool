#!/usr/bin/env bash
# front/ 변경분을 push하기 전에 pnpm test && pnpm run build를 강제한다.
# 배경: vitest(pnpm test)는 타입체크를 하지 않는다(esbuild가 타입을 지우고 트랜스파일만 함).
# 타입 에러는 vue-tsc가 포함된 pnpm run build에서만 걸리는데, 이 훅이 없으면
# 그 검증이 GitHub Actions(push 이후)에서야 처음 실행돼 main이 이미 깨진 채로 남는다.
set -e

repo_root="$(git rev-parse --show-toplevel)"
zero="0000000000000000000000000000000000000000"

# .gitignore에 등록됐는데도 여전히 추적 중인 파일이 있으면 push를 막는다.
# (예: CLAUDE.md가 gitignore 등록 전에 이미 커밋돼 있던 사고 재발 방지 —
#  gitignore는 이미 트래킹 중인 파일에는 소급 적용되지 않는다)
tracked_ignored="$(cd "$repo_root" && git ls-files -ci --exclude-standard)"
if [ -n "$tracked_ignored" ]; then
    echo "❌ pre-push 훅 실패: .gitignore에 등록됐지만 여전히 추적 중인 파일이 있습니다:"
    echo "$tracked_ignored" | sed 's/^/   /'
    echo "   git rm --cached <파일>로 추적을 해제한 뒤 다시 push하세요."
    echo "   훅을 건너뛰려면(권장하지 않음): git push --no-verify"
    exit 1
fi

front_changed=false

while read -r local_ref local_sha remote_ref remote_sha; do
    [ "$local_sha" = "$zero" ] && continue # 브랜치 삭제
    if [ "$remote_sha" = "$zero" ]; then
        # 새 브랜치: main과의 merge-base 기준으로 비교
        base="$(git merge-base origin/main "$local_sha" 2>/dev/null || echo "$local_sha^" 2>/dev/null || echo "$local_sha")"
        range="$base..$local_sha"
    else
        range="$remote_sha..$local_sha"
    fi
    if git diff --name-only "$range" 2>/dev/null | grep -q '^front/'; then
        front_changed=true
    fi
done

if [ "$front_changed" = true ]; then
    echo "pre-push: front/ 변경 감지 — pnpm test && pnpm run build 실행 중..."
    if ! (cd "$repo_root/front" && pnpm test && pnpm run build); then
        echo ""
        echo "❌ pre-push 훅 실패: front 테스트/빌드가 통과하지 않아 push를 막았습니다."
        echo "   훅을 건너뛰려면(권장하지 않음): git push --no-verify"
        exit 1
    fi
fi
