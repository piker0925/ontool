# 로컬 실로그인 테스트용. 이 파일을 복사해 back/.env로 만들고 실제 값을 채운다.
# back/.env는 .gitignore 대상이라 커밋되지 않는다 — 자격증명을 여기(.env.example)에 채우지 말 것.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=
JWT_SECRET=local-dev-only-jwt-secret-please-change-0123456789abcdef
FRONTEND_URL=http://localhost:5173
